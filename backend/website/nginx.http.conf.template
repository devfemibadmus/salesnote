server {
    listen 80;
    server_name {{WEBSITE_NAME}};

    root {{WEBSITE_ROOT}};
    index index.html;

    location = /robots.txt {
        try_files $uri =404;
        access_log off;
        log_not_found off;
    }

    location /assets/ {
        try_files $uri =404;
    }

    location / {
        try_files $uri /index.html;
    }
}
