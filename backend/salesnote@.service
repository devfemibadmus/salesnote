[Unit]
Description=Salesnote API instance %i
After=network.target

[Service]
Type=simple
EnvironmentFile=/home/salesnote/api/.env
Environment=SALESNOTE__BIND=0.0.0.0:%i
Environment=SALESNOTE__INSTANCE_ID=%i
WorkingDirectory=/home/salesnote/api
ExecStart=/home/salesnote/api/api
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
