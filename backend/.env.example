# Salesnote Backend (Example)
LOG_TO_TERMINAL=true
ENABLE_BACKTRACE=true
ENABLE_SQL_ERROR_LOG=true
LOG_DIR=logs
ACCESS_LOG_FILE=access.log
INFO_LOG_FILE=info.log
ERROR_LOG_FILE=error.log

SALESNOTE__BIND=127.0.0.1:8080
SALESNOTE__DATABASE_URL=postgres://salesnote:password123@127.0.0.1:5432/salesnote
SALESNOTE__MAX_REQUEST_PAYLOAD_BYTES=12582912
SALESNOTE__PROFILE_IMAGE_MAX_BYTES=10485760
SALESNOTE__PROFILE_IMAGE_MAX_SOURCE_DIMENSION=5000
SALESNOTE__PROFILE_IMAGE_MAX_SOURCE_PIXELS=16000000
SALESNOTE__SIGNATURE_IMAGE_MAX_BYTES=10485760
SALESNOTE__SIGNATURE_IMAGE_MAX_SOURCE_DIMENSION=5000
SALESNOTE__SIGNATURE_IMAGE_MAX_SOURCE_PIXELS=16000000
SALESNOTE__POOL_MAX_SIZE=50
SALESNOTE__POOL_MIN_IDLE=10
SALESNOTE__JWT_SECRET=change_me
SALESNOTE__REFRESH_TOKEN_DAYS=30
SALESNOTE__RATE_LIMIT_PER_MINUTE=120
SALESNOTE__AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
SALESNOTE__AUTH_REGISTER_RATE_LIMIT_PER_MINUTE=5
SALESNOTE__AUTH_REGISTER_VERIFY_RATE_LIMIT_PER_MINUTE=10
SALESNOTE__AUTH_FORGOT_PASSWORD_RATE_LIMIT_PER_MINUTE=5
SALESNOTE__AUTH_VERIFY_CODE_RATE_LIMIT_PER_MINUTE=10
SALESNOTE__AUTH_RESET_PASSWORD_RATE_LIMIT_PER_MINUTE=10
SALESNOTE__FORGOT_PASSWORD_MAX_REQUESTS=2
SALESNOTE__FORGOT_PASSWORD_WINDOW_MINUTES=120
SALESNOTE__RESET_CODE_MAX_INCORRECT_ATTEMPTS=5
SALESNOTE__TRUSTED_PROXY_RANGES=127.0.0.1/32,::1/128
SALESNOTE__PASSWORD_MIN_CHARS=8
SALESNOTE__PASSWORD_MAX_CHARS=128
SALESNOTE__REDIS_URL=redis://127.0.0.1:6379

SALESNOTE__SMTP_FROM="Salesnote <no-reply@example.com>"
SALESNOTE__SMTP_HOST=smtp.example.com
SALESNOTE__SMTP_PORT=465
SALESNOTE__SMTP_USERNAME=user@example.com
SALESNOTE__SMTP_PASSWORD=change_me
SALESNOTE__SMTP_TIMEOUT_SECS=20
SALESNOTE__SMTP_TEST_TO=test@example.com

SALESNOTE__DASHBOARD_URL=https://salesnote.ng
SALESNOTE__FCM_PROJECT_ID=your-project-id
SALESNOTE__FCM_KEY_JSON_PATH=firebase-adminsdk.json
SALESNOTE__GEOIP_URL=https://ipinfo.io/{ip}/json?token=YOUR_TOKEN
SALESNOTE__GEOIP_TOKEN=

# Nginx (optional)
NGINX_SERVER_NAME=your-domain.com

# Optional seed/backup
SALESNOTE__SEED_SHOP_NAME="Demo Shop"
SALESNOTE__SEED_SHOP_PHONE=08012345678
SALESNOTE__SEED_SHOP_EMAIL=demo@salesnote.ng
SALESNOTE__SEED_SHOP_PASSWORD=demo123
SALESNOTE__SEED_SHOP_ADDRESS="12 Lagos Island Market"
SALESNOTE__SEED_SIGNATURE_URL=https://aisignator.com/wp-content/uploads/2025/05/Amanda-signature.jpg
SALESNOTE__BACKUP_PATH=backups/salesnote_backup.dump
